---
import Layout from "../layouts/Layout.astro";

const timeline = [
  { year: "1568", text: "I Ferreri acquistano il feudo di Cacchiamo" },
  { year: "XVI sec.", text: "Edificazione della masseria fortificata" },
  { year: "1733", text: "Trasformazione in villa dei Bongiorno" },
  { year: "1998", text: "Vincolo storico monumentale" },
];
---

<Layout hero title="Home" description="Villa Masseria Cacchiamo — Restauro e valorizzazione dell'architettura rurale siciliana">
  <!-- Hero -->
  <section class="page-hero relative min-h-[100dvh] flex items-end overflow-hidden">
    <div class="absolute -inset-y-[10%] inset-x-0" data-parallax>
      <img
        src="/images/home/hero-aerial.jpg"
        alt="Villa Masseria Cacchiamo vista aerea"
        class="w-full h-full object-cover hero-zoom"
        fetchpriority="high"
      />
    </div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-black/10"></div>
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 md:px-8 lg:px-12 pb-20 md:pb-28 text-protect">
      <div class="max-w-4xl">
        <p class="eyebrow is-light mb-6">Architettura rurale siciliana · XVI secolo</p>
        <h1 class="js-line font-serif text-white text-6xl md:text-7xl lg:text-8xl leading-[1.0]">
          <span class="line-mask"><span class="line-inner">Villa Masseria</span></span>
          <span class="line-mask"><span class="line-inner">Cacchiamo</span></span>
        </h1>
        <p class="font-sans text-base md:text-lg text-white/75 font-light max-w-xl mt-8 reveal-up">
          Restauro e valorizzazione di un gioiello architettonico del XVI secolo, nel cuore della Sicilia.
        </p>
      </div>
    </div>
    <div class="absolute bottom-8 right-6 md:right-12 z-10 hidden sm:flex flex-col items-center gap-3 text-white/55">
      <span class="text-[11px] uppercase tracking-[0.22em] [writing-mode:vertical-rl]">Scorri</span>
      <span class="w-px h-12 bg-white/30 overflow-hidden relative">
        <span class="absolute inset-x-0 top-0 h-1/2 bg-white/80 animate-[scrollHint_2s_ease-in-out_infinite]"></span>
      </span>
    </div>
  </section>

  <!-- La Storia (editoriale, asimmetrico) -->
  <section class="py-24 md:py-36 px-6 md:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
        <div class="lg:col-span-5 lg:sticky lg:top-32 self-start reveal-up">
          <p class="eyebrow mb-6">La Storia</p>
          <h2 class="font-serif text-4xl md:text-5xl text-espresso leading-[1.08]">
            Un viaggio nel tempo nel cuore della Sicilia
          </h2>
          <p class="text-espresso/55 leading-relaxed text-base mt-6 max-w-md">
            All'incrocio delle tre valli, sullo spartiacque che divide la Sicilia, la villa custodisce cinque secoli di storia.
          </p>
        </div>
        <div class="lg:col-span-6 lg:col-start-7 space-y-6 text-espresso/65 leading-relaxed text-base md:text-lg reveal-up">
          <p>
            La villa masseria fu edificata nella seconda metà del XVI secolo dai Ferreri di Savona nella proprietà del borgo feudale di Cacchiamo, appartenuto alla famiglia dei Ventimiglia. Dalla corte principale si accede, tramite uno scalone monumentale a tenaglia, al piano nobile i cui ambienti sono stati oggetto di un restauro finanziato dal PNRR.
          </p>
          <p>
            Nel 1733 la masseria venne acquistata dal barone Francesco Bongiorno di Gangi, che affidò al fratello architetto Gandolfo Felice Bongiorno la trasformazione in villa della masseria fortificata tardo medievale, con forti riferimenti alle ville coeve della Piana dei Colli di Palermo.
          </p>
          <p>
            L'apparato decorativo in stile Rococò, commissionato alla bottega del Fumagalli, impreziosisce i due ambienti aggiunti sul lato Ovest del piano nobile con pannelli dipinti incorniciati da elementi mistilinei in stucco.
          </p>
        </div>
      </div>

      <!-- Timeline strip -->
      <div class="mt-20 md:mt-28 pt-10 border-t border-espresso/10">
        <ol class="grid grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-10" data-reveal-stagger>
          {timeline.map((t) => (
            <li class="relative pl-5">
              <span class="absolute left-0 top-1.5 w-1.5 h-1.5 rounded-full bg-accent" aria-hidden="true"></span>
              <p class="font-serif text-2xl md:text-3xl text-espresso">{t.year}</p>
              <p class="text-sm text-espresso/55 leading-snug mt-2 max-w-[15rem]">{t.text}</p>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- Galleria orizzontale: la villa -->
  <section class="py-20 md:py-28 bg-sage overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 md:px-8 mb-12 md:mb-16 reveal-up">
      <p class="eyebrow mb-5">Immagini</p>
      <h2 class="font-serif text-4xl md:text-5xl text-espresso leading-[1.08] max-w-2xl">
        La villa tra storia e paesaggio
      </h2>
    </div>
    <div id="villa-gallery" class="gallery-scroll">
      <div class="img-zoom"><img src="/images/home/villa-green.jpg" alt="Villa Masseria Cacchiamo" loading="lazy" decoding="async" /></div>
      <div class="img-zoom"><img src="/images/home/villa-sud.jpg" alt="Villa vista da sud" loading="lazy" decoding="async" /></div>
      <div class="img-zoom"><img src="/images/home/villa-bevaio.jpg" alt="Il bevaio cinquecentesco" loading="lazy" decoding="async" /></div>
    </div>
    <div id="villa-dots" class="gallery-dots" role="tablist" aria-label="Indicatori galleria"></div>
  </section>

  <!-- Prima / Dopo: slider interattivo -->
  <section class="py-24 md:py-36 px-6 md:px-8">
    <div class="max-w-5xl mx-auto">
      <div class="mb-10 md:mb-14 reveal-up">
        <p class="eyebrow mb-5">Prima e dopo</p>
        <h2 class="font-serif text-4xl md:text-5xl text-espresso leading-[1.08]">
          Il restauro delle decorazioni
        </h2>
        <p class="text-sm text-espresso/55 max-w-md mt-4">
          Lo stato di conservazione delle superfici policrome prima e dopo l'intervento.
        </p>
      </div>
      <div class="grid grid-cols-2 gap-3 md:gap-4 reveal-scale">
        <div class="relative figure-frame img-zoom">
          <span class="photo-tag">Prima</span>
          <img src="/images/restauro/fig07.jpg" alt="Le decorazioni prima del restauro" class="w-full aspect-[4/5] object-cover" loading="lazy" decoding="async" />
        </div>
        <div class="relative figure-frame img-zoom">
          <span class="photo-tag">Dopo</span>
          <img src="/images/fine-restauro/Foto%2009.jpg" alt="Le decorazioni dopo il restauro" class="w-full aspect-[4/5] object-cover" loading="lazy" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <!-- Pausa scura: citazione -->
  <section class="bg-espresso text-cream py-24 md:py-36 px-6 md:px-8 overflow-hidden">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <div class="lg:col-span-7 reveal-up">
        <p class="eyebrow is-light mb-8">Il luogo</p>
        <blockquote class="pull-quote text-3xl md:text-4xl lg:text-5xl text-cream/90">
          “All'incrocio delle tre valli, sullo spartiacque che divide la Sicilia, lungo l'antica direttrice della transumanza.”
        </blockquote>
        <p class="text-sm text-cream/45 mt-8 tracking-wide">Villa Masseria Cacchiamo — Calascibetta, Enna</p>
      </div>
      <div class="lg:col-span-5 img-zoom figure-frame aspect-[4/5] reveal-scale">
        <img src="/images/home/villa-nord.jpg" alt="La villa vista da nord" class="w-full h-full object-cover" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  <!-- CTA Restauro -->
  <section class="py-24 md:py-32 px-6 md:px-8 bg-sage">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="reveal-up md:order-last">
        <div class="img-zoom figure-frame aspect-[4/3]">
          <img src="/images/home/abbeveratoio.jpg" alt="Abbeveratoio cinquecentesco" class="w-full h-full object-cover" loading="lazy" decoding="async" />
        </div>
      </div>
      <div class="reveal-up md:order-first">
        <p class="eyebrow mb-5">Il Restauro</p>
        <h2 class="font-serif text-4xl md:text-5xl text-espresso leading-[1.08] mb-6">
          Recupero e valorizzazione
        </h2>
        <p class="text-espresso/60 leading-relaxed mb-8 text-base md:text-lg max-w-md">
          Un progetto di risanamento conservativo e recupero funzionale finanziato dal PNRR (M1C3 – Intervento 2.2) per la protezione e valorizzazione dell'architettura e del paesaggio rurale.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/progetto-restauro" class="btn btn-primary interactive">Il Progetto</a>
          <a href="/fine-restauro" class="btn btn-white interactive">Il Restauro</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Mappa storica -->
  <section class="py-24 md:py-36 px-6 md:px-8">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12 reveal-up">
        <p class="eyebrow is-centered mb-5">Mappa storica</p>
        <h2 class="font-serif text-4xl md:text-5xl text-espresso leading-[1.08]">
          La Sicilia del 1721
        </h2>
      </div>
      <div class="figure-frame reveal-scale">
        <img src="/images/home/mappa-1721.png" alt="Estratto dalla carta della Sicilia del 1721, redatta dal Barone von Schmettau" class="w-full object-contain" loading="lazy" decoding="async" />
      </div>
      <p class="text-sm text-espresso/55 mt-6 italic max-w-2xl mx-auto text-center">
        Estratto dalla carta della Sicilia del 1721, redatta dal Barone von Schmettau. In corrispondenza del sito della masseria di Cacchiamo viene segnalato un magazzeno.
      </p>
    </div>
  </section>
</Layout>

<script>
  const gallery = document.getElementById("villa-gallery");
  const dotsWrap = document.getElementById("villa-dots");
  if (gallery && dotsWrap) {
    const slides = Array.from(gallery.children) as HTMLElement[];
    const reduced = !window.matchMedia("(prefers-reduced-motion: no-preference)").matches;
    let current = 0;
    let timer: ReturnType<typeof setInterval> | null = null;

    slides.forEach((_, i) => {
      const b = document.createElement("button");
      b.className = "gallery-dot";
      b.setAttribute("role", "tab");
      b.setAttribute("aria-label", `Vai all'immagine ${i + 1}`);
      b.addEventListener("click", () => goTo(i, true));
      dotsWrap.appendChild(b);
    });
    const dots = Array.from(dotsWrap.children) as HTMLElement[];

    const setActive = (i: number) => {
      current = i;
      dots.forEach((d, j) => {
        d.classList.toggle("is-active", j === i);
        d.setAttribute("aria-selected", String(j === i));
      });
    };
    const goTo = (i: number, user?: boolean) => {
      i = (i + slides.length) % slides.length;
      slides[i].scrollIntoView({ behavior: reduced ? "auto" : "smooth", inline: "start", block: "nearest" });
      setActive(i);
      if (user) restart();
    };

    let raf = 0;
    gallery.addEventListener("scroll", () => {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => {
        const gl = gallery.getBoundingClientRect().left;
        let nearest = 0, min = Infinity;
        slides.forEach((s, j) => {
          const d = Math.abs(s.getBoundingClientRect().left - gl);
          if (d < min) { min = d; nearest = j; }
        });
        setActive(nearest);
      });
    }, { passive: true });

    let visible = false;
    let hovered = false;
    const start = () => { if (!reduced && !timer && visible && !hovered) timer = setInterval(() => goTo(current + 1), 5000); };
    const stop = () => { if (timer) { clearInterval(timer); timer = null; } };
    const restart = () => { stop(); start(); };
    gallery.addEventListener("pointerenter", () => { hovered = true; stop(); });
    gallery.addEventListener("pointerleave", () => { hovered = false; start(); });
    gallery.addEventListener("touchstart", stop, { passive: true });

    // Autoplay only while the gallery is on screen, so it never yanks the page
    new IntersectionObserver((entries) => {
      visible = entries[0].isIntersecting;
      visible ? start() : stop();
    }, { threshold: 0.4 }).observe(gallery);

    setActive(0);
  }
</script>

<style>
  @keyframes scrollHint {
    0% { transform: translateY(-100%); }
    50% { transform: translateY(100%); }
    100% { transform: translateY(100%); }
  }
</style>
