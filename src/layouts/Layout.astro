---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const path = Astro.url.pathname;
const navItems = [
  { href: "/", label: "Home" },
  { href: "/progetto-restauro", label: "Progetto" },
  { href: "/fine-restauro", label: "Restauro" },
  { href: "/contatti", label: "Contatti" },
];
---

<html lang="it">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://use.typekit.net/mdf2qwa.css" />
    <link href="https://fonts.googleapis.com/css2?family=Teachers:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title} | Villa Masseria Cacchiamo</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body class="bg-cream text-stone-700 font-sans antialiased">
    <a href="#main-content" class="skip-link">Vai al contenuto principale</a>

    <div class="nav-enter fixed top-3 md:top-6 left-1/2 -translate-x-1/2 z-50">
      <nav class="flex items-center gap-1 bg-white/90 backdrop-blur-2xl border border-stone-200/60 rounded-full px-2 py-1.5 shadow-[0_8px_32px_rgba(0,0,0,0.06)]" aria-label="Navigazione principale">
        <a href="/" class="font-serif text-sm text-espresso px-3 md:px-4 py-1.5 hover:text-espresso/60 transition-colors" aria-label="Vai alla homepage">
          Villa Masseria Cacchiamo
        </a>
        <span class="w-px h-5 bg-stone-200/60" aria-hidden="true"></span>
        {navItems.map((item) => (
          <a
            href={item.href}
            aria-current={path === item.href ? "page" : undefined}
            class={`
              nav-link font-sans text-[13px] tracking-[0.15em] uppercase rounded-full transition-all duration-300
              ${path === item.href
                ? "text-espresso"
                : "text-espresso/30 hover:text-espresso/60"
              }
            `}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>

    <main id="main-content">
      <slot />
    </main>

    <footer class="border-t border-stone-200 bg-cream" role="contentinfo">
      <div class="max-w-6xl mx-auto px-6 py-20">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
          <div class="md:col-span-2">
            <h2 class="font-serif text-xl text-espresso mb-4 text-base">Villa Masseria Cacchiamo</h2>
            <p class="text-sm text-espresso/70 leading-relaxed max-w-sm">
              Restauro e valorizzazione dell'architettura rurale siciliana. Un gioiello del XVI secolo nel cuore della Sicilia.
            </p>
          </div>
          <div>
            <h3 class="text-xs tracking-[0.2em] uppercase text-espresso/50 mb-4 font-medium">Contatti</h3>
            <p class="text-sm text-espresso/70 leading-relaxed">
              Dott.ssa Luisa Stella<br />
              <a href="mailto:info@villamasseriacacchiamo.it" class="underline underline-offset-2 hover:text-espresso transition-colors">info@villamasseriacacchiamo.it</a>
            </p>
          </div>
          <div>
            <h3 class="text-xs tracking-[0.2em] uppercase text-espresso/50 mb-4 font-medium">Luogo</h3>
            <p class="text-sm text-espresso/70 leading-relaxed">
              Cacchiamo<br />
              Calascibetta (EN), Sicilia
            </p>
          </div>
        </div>
        <div class="mt-16 pt-8 border-t border-stone-200 flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-xs text-espresso/50">
            &copy; {new Date().getFullYear()} Villa Masseria Cacchiamo
          </p>
          <p class="text-xs text-espresso/50">
            Design <a href="https://www.hypebang.it" target="_blank" rel="noopener" class="underline underline-offset-2 hover:text-espresso transition-colors" aria-label="HYPEBANG Studio — apre in nuova finestra">HYPEBANG Studio</a>
          </p>
        </div>
      </div>
    </footer>

    <script>
      if (window.matchMedia("(prefers-reduced-motion: no-preference)").matches) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
              }
            });
          },
          { threshold: 0.1 }
        );
        document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
      } else {
        document.querySelectorAll(".reveal").forEach((el) => el.classList.add("visible"));
      }
    </script>
  </body>
</html>
