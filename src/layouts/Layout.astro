---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const path = Astro.url.pathname;
---

<html lang="it">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Raleway:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <title>{title} | Villa Masseria Cacchiamo</title>
    {description && <meta name="description" content={description} />}
  </head>
    <body class="bg-stone-50 text-stone-700 font-sans antialiased">
    <header class="fixed top-0 left-0 right-0 z-50 bg-stone-50/90 backdrop-blur-sm border-b border-stone-200/50">
      <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="font-serif text-lg tracking-normal text-stone-700 hover:text-stone-900 transition-colors">
          Villa Masseria Cacchiamo
        </a>
        <div class="flex items-center gap-8 text-sm font-sans">
          <a href="/" class={`tracking-wide transition-colors ${path === "/" ? "text-stone-900" : "text-stone-500 hover:text-stone-800"}`}>
            Home
          </a>
          <a href="/progetto-restauro" class={`tracking-wide transition-colors ${path === "/progetto-restauro" ? "text-stone-900" : "text-stone-500 hover:text-stone-800"}`}>
            Progetto
          </a>
          <a href="/fine-restauro" class={`tracking-wide transition-colors ${path === "/fine-restauro" ? "text-stone-900" : "text-stone-500 hover:text-stone-800"}`}>
            Restauro
          </a>
          <a href="/contatti" class={`tracking-wide transition-colors ${path === "/contatti" ? "text-stone-900" : "text-stone-500 hover:text-stone-800"}`}>
            Contatti
          </a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-stone-200 bg-stone-100">
      <div class="max-w-6xl mx-auto px-6 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-xs tracking-widest uppercase text-stone-400 mb-3">Villa Masseria Cacchiamo</h3>
            <p class="text-sm text-stone-500 leading-relaxed">
              Restauro e valorizzazione dell'architettura rurale siciliana.
            </p>
          </div>
          <div>
            <h3 class="text-xs tracking-widest uppercase text-stone-400 mb-3">Contatti</h3>
            <p class="text-sm text-stone-500 leading-relaxed">
              Dott.ssa Luisa Stella<br />
              Email: info@villamasseriacacchiamo.it
            </p>
          </div>
          <div>
            <h3 class="text-xs tracking-widest uppercase text-stone-400 mb-3">Luogo</h3>
            <p class="text-sm text-stone-500 leading-relaxed">
              Cacchiamo, Calascibetta (EN)<br />
              Sicilia
            </p>
          </div>
        </div>
        <div class="mt-8 pt-8 border-t border-stone-200 text-center">
          <p class="text-xs text-stone-400">&copy; {new Date().getFullYear()} Villa Masseria Cacchiamo</p>
        </div>
      </div>
    </footer>
  </body>
</html>
